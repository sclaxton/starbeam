{
  "name": "@starbeamx/store",
  "type": "module",
  "version": "0.9.0",
  "description": "Experimental reactive table, query, grouping, and aggregation APIs for Starbeam",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    "default": "./index.ts"
  },
  "publishConfig": {
    "exports": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "starbeam": {
    "type": "library:public"
  },
  "scripts": {
    "build": "rollup -c",
    "prepack": "pnpm build",
    "test:lint": "eslint . --max-warnings 0",
    "test:specs": "vitest --run --pool forks",
    "test:types": "tsc -b"
  },
  "dependencies": {
    "@starbeam/collections": "workspace:^",
    "@starbeam/interfaces": "workspace:^",
    "@starbeam/reactive": "workspace:^"
  },
  "devDependencies": {
    "@starbeam-dev/compile": "workspace:*",
    "rollup": "^4.60.1"
  },
  "release-plan": {
    "semverIncrementAs": {
      "major": "minor"
    }
  },
  "repository": {
    "directory": "packages/x/store",
    "type": "git",
    "url": "https://github.com/starbeamjs/starbeam"
  }
}
