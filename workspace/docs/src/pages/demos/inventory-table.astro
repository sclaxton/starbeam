---
import "@fontsource/geist-sans";
import "@starbeam-demos/table-react/src/styles.css";

import DemoSourceCard from "../../components/DemoSourceCard.astro";
import PreactInventoryDemo from "../../components/PreactInventoryDemo";
import ReactInventoryDemo from "../../components/ReactInventoryDemo";
import SourceDisclosure from "../../components/SourceDisclosure.astro";
import StarMark from "../../components/StarMark.astro";
import "../../styles/tokens.css";
import inventorySourceCards from "../../generated/inventory-source-cards.json";
import inventoryModelSource from "@starbeam-demos/table-core/src/table.ts?raw";
import reactShellSource from "@starbeam-demos/table-react/src/App.tsx?raw";
import preactShellSource from "@starbeam-demos/table-preact/src/App.tsx?raw";

const SOURCE_URLS = {
  model:
    "https://github.com/starbeamjs/starbeam/blob/main/demos/table-core/src/table.ts",
  react:
    "https://github.com/starbeamjs/starbeam/blob/main/demos/table-react/src/App.tsx",
  preact:
    "https://github.com/starbeamjs/starbeam/blob/main/demos/table-preact/src/App.tsx",
} as const;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Inventory table demo · Starbeam</title>
    <meta
      name="description"
      content="A Starbeam inventory table demo embedded in the docs with React and Preact shells."
    />
  </head>
  <body>
    <header class="docs-demo-topbar">
      <a class="docs-demo-brand" href="/" aria-label="Starbeam home">
        <StarMark class="docs-demo-brand__mark" />
        <span>Starbeam</span>
      </a>
      <nav aria-label="Demo navigation">
        <a href="/start/introduction/">Docs</a>
        <a href="/frameworks/overview/">Frameworks</a>
        <a href="https://github.com/starbeamjs/starbeam/tree/main/demos">
          Source
        </a>
      </nav>
    </header>

    <section class="docs-demo-intro" aria-labelledby="demo-heading">
      <p class="docs-demo-label">Embedded demos</p>
      <h1 id="demo-heading">One table model, multiple framework edges.</h1>
      <p>
        Use the tabs below to switch between framework shells. Each tab renders
        a different adapter boundary against the same framework-neutral
        <code>@starbeam-demos/table-core</code> inventory model.
      </p>
    </section>

    <section class="shared-source" aria-label="Shared table model source">
      <SourceDisclosure
        label="Shared source"
        title="Table model"
        path="@starbeam-demos/table-core/src/table.ts"
        hint="React, Preact, and future shells import this package."
      >
        <p>
          Ordinary TypeScript owns the table state. The framework shells only
          decide how reads connect to rendering.
        </p>
        <DemoSourceCard
          eyebrow="Universal source"
          title="@starbeam-demos/table-core/src/table.ts"
          githubUrl={SOURCE_URLS.model}
          rawSource={inventoryModelSource}
          code={inventoryModelSource}
          lang="ts"
          meta="twoslash"
          renderedHtml={inventorySourceCards.cards.model.html}
          renderedSourceHash={inventorySourceCards.cards.model.sourceHash}
        />
      </SourceDisclosure>
    </section>

    <section class="docs-demo-tabs-section" aria-labelledby="framework-demo-heading">
      <div class="docs-demo-heading-row">
        <div>
          <p class="docs-demo-label">Framework shells</p>
          <h2 id="framework-demo-heading">Same model, different adapter.</h2>
        </div>
      </div>

      <div class="demo-tabs" data-demo-tabs>
        <div class="demo-tab-list" role="tablist" aria-label="Framework demos">
          <button
            id="react-demo-tab"
            class="demo-tab is-active"
            type="button"
            role="tab"
            aria-selected="true"
            aria-controls="react-demo-panel"
            data-demo-tab="react"
          >
            <span>React</span>
          </button>
          <button
            id="preact-demo-tab"
            class="demo-tab"
            type="button"
            role="tab"
            aria-selected="false"
            aria-controls="preact-demo-panel"
            tabindex="-1"
            data-demo-tab="preact"
          >
            <span>Preact</span>
          </button>
        </div>

        <section
          id="react-demo-panel"
          class="docs-demo-panel is-active"
          role="tabpanel"
          aria-labelledby="react-demo-tab"
          data-demo-panel="react"
        >
          <div class="demo-panel-header">
            <p>
              The React shell wraps the table read in <code>useReactive()</code>
              and keeps mutations in event handlers.
            </p>
          </div>
          <ReactInventoryDemo client:only="react" />
          <SourceDisclosure
            label="Framework source"
            title="React shell"
            filename="App.tsx"
          >
            <DemoSourceCard
              eyebrow="React shell"
              title="@starbeam-demos/table-react/src/App.tsx"
              githubUrl={SOURCE_URLS.react}
              rawSource={reactShellSource}
              code={reactShellSource}
              lang="tsx"
              meta="twoslash"
              renderedHtml={inventorySourceCards.cards.react.html}
              renderedSourceHash={inventorySourceCards.cards.react.sourceHash}
            />
          </SourceDisclosure>
        </section>

        <section
          id="preact-demo-panel"
          class="docs-demo-panel"
          role="tabpanel"
          aria-labelledby="preact-demo-tab"
          data-demo-panel="preact"
          hidden
        >
          <div class="demo-panel-header">
            <p>
              The Preact shell installs <code>@starbeam/preact</code> once, then
              reads the table directly while rendering.
            </p>
          </div>
          <PreactInventoryDemo client:only="preact" />
          <SourceDisclosure
            label="Framework source"
            title="Preact shell"
            filename="App.tsx"
          >
            <DemoSourceCard
              eyebrow="Preact shell"
              title="@starbeam-demos/table-preact/src/App.tsx"
              githubUrl={SOURCE_URLS.preact}
              rawSource={preactShellSource}
              code={preactShellSource}
              lang="tsx"
              meta="twoslash"
              renderedHtml={inventorySourceCards.cards.preact.html}
              renderedSourceHash={inventorySourceCards.cards.preact.sourceHash}
            />
          </SourceDisclosure>
        </section>
      </div>
    </section>

    <script>
      for (const tabSet of document.querySelectorAll("[data-demo-tabs]")) {
        const tabs = [
          ...tabSet.querySelectorAll<HTMLButtonElement>("[data-demo-tab]"),
        ];
        const panels = [
          ...tabSet.querySelectorAll<HTMLElement>("[data-demo-panel]"),
        ];

        function selectTab(tab: HTMLButtonElement): void {
          const target = tab.getAttribute("data-demo-tab");

          for (const currentTab of tabs) {
            const isSelected = currentTab === tab;
            currentTab.classList.toggle("is-active", isSelected);
            currentTab.setAttribute("aria-selected", String(isSelected));
            currentTab.tabIndex = isSelected ? 0 : -1;
          }

          for (const panel of panels) {
            const isSelected = panel.getAttribute("data-demo-panel") === target;
            panel.classList.toggle("is-active", isSelected);
            panel.hidden = !isSelected;
          }
        }

        for (const tab of tabs) {
          tab.addEventListener("click", () => selectTab(tab));

          tab.addEventListener("keydown", (event) => {
            if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") {
              return;
            }

            event.preventDefault();

            const offset = event.key === "ArrowRight" ? 1 : -1;
            const nextIndex = (tabs.indexOf(tab) + offset + tabs.length) % tabs.length;
            const nextTab = tabs[nextIndex];

            if (nextTab) {
              nextTab.focus();
              selectTab(nextTab);
            }
          });
        }
      }

      for (const button of document.querySelectorAll<HTMLButtonElement>(
        "[data-copy-code]",
      )) {
        button.addEventListener("click", async () => {
          const card = button.closest("[data-code-card]");
          const code = card?.querySelector<HTMLTextAreaElement>(
            "[data-copy-source]",
          )?.value;

          if (!code) {
            return;
          }

          const readyText = button.textContent ?? "Copy";

          try {
            await navigator.clipboard.writeText(code);
            button.textContent = "Copied";
          } catch {
            button.textContent = "Copy failed";
          }

          setTimeout(() => {
            button.textContent = readyText;
          }, 1600);
        });
      }
    </script>
  </body>
</html>

<style>
  body {
    margin: 0;
  }

  .docs-demo-topbar,
  .docs-demo-intro,
  .docs-demo-tabs-section,
  .shared-source {
    margin-inline: auto;
    width: min(88rem, calc(100vw - clamp(2rem, 5vw, 4rem)));
  }

  .docs-demo-topbar {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    padding-block: clamp(1rem, 3vw, 1.6rem) 0;
  }

  .docs-demo-brand {
    align-items: center;
    color: var(--ink);
    display: inline-flex;
    font-size: 0.95rem;
    font-weight: 900;
    gap: 0.75rem;
    letter-spacing: 0.34em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .docs-demo-brand__mark {
    --star-mark-size: 2.35rem;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  nav a,
  .docs-demo-link {
    color: var(--green);
    font-weight: 760;
    text-decoration: none;
  }

  nav a:hover,
  .docs-demo-link:hover {
    color: var(--green-dark);
  }

  .docs-demo-intro {
    padding-block: clamp(3rem, 7vw, 5.5rem) clamp(1.5rem, 4vw, 3rem);
  }

  .docs-demo-label {
    color: var(--green);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }

  h1 {
    color: var(--ink);
    font-family: "Iowan Old Style", "Palatino Linotype", Palatino, Georgia,
      serif;
    font-size: clamp(3.2rem, 7vw, 6.75rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 0.98;
    margin: 0;
    max-width: 12ch;
  }

  .docs-demo-intro p:last-child {
    color: var(--muted);
    font-size: clamp(1.05rem, 1.5vw, 1.22rem);
    line-height: 1.7;
    margin-block: 1.4rem 0;
    max-width: 50rem;
  }

  code {
    background: rgba(255, 250, 241, 0.82);
    border: 1px solid var(--line);
    border-radius: var(--radius-tight);
    color: var(--green-dark);
    padding: 0.1rem 0.24rem;
  }

  .shared-source {
    margin-block-end: clamp(2rem, 5vw, 4rem);
  }

  .shared-source p,
  .demo-panel-header p {
    color: var(--muted);
    line-height: 1.6;
  }

  .shared-source p {
    margin-block: 0 var(--space-3);
    max-width: 54rem;
  }

  .docs-demo-tabs-section {
    padding-block-end: clamp(3rem, 6vw, 5rem);
  }

  .docs-demo-heading-row {
    align-items: end;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin-block-end: 1rem;
  }

  h2 {
    color: var(--ink);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    letter-spacing: -0.03em;
    margin: 0;
  }

  .demo-tab-list {
    align-items: center;
    border-bottom: 1px solid var(--line);
    display: flex;
    gap: 1.25rem;
    margin-block: var(--space-3) var(--space-4);
    padding: 0;
  }

  .demo-tab {
    align-items: center;
    background: transparent;
    border: 0;
    border-bottom: 2px solid transparent;
    border-radius: 0;
    box-shadow: none;
    color: var(--muted);
    display: inline-flex;
    min-height: 0;
    padding: 0.62rem 0.1rem 0.72rem;
  }

  .demo-tab:hover {
    color: var(--ink);
  }

  .demo-tab span {
    color: inherit;
    font-size: 0.96rem;
    font-weight: 820;
  }

  .demo-tab.is-active {
    background: transparent;
    border-bottom-color: var(--green);
    color: var(--green-dark);
  }

  .docs-demo-panel[hidden] {
    display: none;
  }

  .demo-panel-header {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin-block-end: var(--space-4);
  }

  .demo-panel-header p {
    margin: 0;
    max-width: 46rem;
  }

  .docs-demo-panel :global(.shell) {
    margin-inline: 0;
    max-width: none;
    padding: 0;
  }

  .docs-demo-panel :global(.source-disclosure) {
    margin-block-start: var(--space-3);
  }

  @media (max-width: 760px) {
    .docs-demo-topbar,
    .docs-demo-heading-row,
    .demo-panel-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .demo-tab-list {
      align-items: stretch;
      flex-direction: column;
      gap: 0;
    }

  }
</style>