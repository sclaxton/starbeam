---
import BrandHero from "../components/BrandHero.astro";
import StarMark from "../components/StarMark.astro";
import "../styles/tokens.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Starbeam</title>
    <meta
      name="description"
      content="Starbeam is reactivity that stays JavaScript."
    />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/" aria-label="Starbeam home">
        <StarMark class="brand__mark" />
        <span>Starbeam</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="/start/introduction/">Docs</a>
        <a href="/frameworks/overview/">Frameworks</a>
        <a href="https://github.com/starbeamjs/starbeam">GitHub</a>
      </nav>
    </header>

    <main>
      <BrandHero />

      <section class="principles" aria-labelledby="principles-heading">
        <div>
          <p class="section-label">Why Starbeam?</p>
          <h2 id="principles-heading">Keep the reactive boundary small.</h2>
        </div>
        <div class="principle-grid">
          <article>
            <span aria-hidden="true">◈</span>
            <h3>Mark root state</h3>
            <p>Cells and reactive collections hold the state Starbeam tracks.</p>
          </article>
          <article>
            <span aria-hidden="true">✦</span>
            <h3>Build domain-shaped APIs</h3>
            <p>Expose values like <code>session.user</code> and <code>form.isValid</code>.</p>
          </article>
          <article>
            <span aria-hidden="true">&lt;/&gt;</span>
            <h3>Stay legible together</h3>
            <p>Humans and agents can both work with stable JavaScript structure.</p>
          </article>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  body {
    background:
      radial-gradient(circle at 90% 4%, rgb(0 194 179 / 14%), transparent 30rem),
      radial-gradient(circle at 0% 18%, rgb(255 219 77 / 12%), transparent 24rem),
      linear-gradient(180deg, #ffffff 0%, var(--starbeam-page) 78%, #eefafa 100%);
    color: var(--starbeam-text);
    font-family: var(--starbeam-font-ui);
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  .topbar {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin: 0 auto;
    padding: clamp(1rem, 3vw, 1.6rem) clamp(0.5rem, 2vw, 1rem) 0;
    width: min(88rem, calc(100vw - clamp(2rem, 5vw, 4rem)));
  }

  .brand {
    align-items: center;
    color: var(--starbeam-ink);
    display: inline-flex;
    font-size: 0.95rem;
    font-weight: 900;
    gap: 0.75rem;
    letter-spacing: 0.34em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .brand__mark {
    filter: drop-shadow(0 8px 14px rgb(30 36 54 / 10%));
    --star-mark-size: 2.35rem;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  nav a {
    color: var(--starbeam-muted);
    font-size: 0.95rem;
    font-weight: 760;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--starbeam-link);
  }

  .principles {
    display: grid;
    gap: clamp(2rem, 4vw, 3.5rem);
    margin: 0 auto clamp(4rem, 8vw, 7rem);
    padding: 0 clamp(0.5rem, 2vw, 1rem);
    width: min(88rem, calc(100vw - clamp(2rem, 5vw, 4rem)));
  }

  .section-label {
    color: var(--starbeam-link);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.24em;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }

  h2 {
    color: var(--starbeam-ink);
    font-family: var(--starbeam-font-display);
    font-size: clamp(2.5rem, 5.4vw, 5.2rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 0.92;
    margin: 0;
    max-width: 12ch;
    word-spacing: 0.08em;
  }

  .principle-grid {
    display: grid;
    gap: clamp(0.85rem, 2vw, 1.25rem);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  article {
    background: var(--starbeam-glass-rail);
    border: 1px solid var(--starbeam-glass-border);
    border-radius: var(--starbeam-radius-lg);
    box-shadow: var(--starbeam-shadow-soft);
    padding: clamp(1.2rem, 3vw, 2rem);
  }

  article span {
    color: var(--starbeam-beam);
    font-weight: 900;
  }

  h3 {
    color: var(--starbeam-ink);
    margin: 0.75rem 0 0.5rem;
  }

  article p {
    color: var(--starbeam-muted);
    line-height: 1.6;
    margin: 0;
  }

  article code {
    background: var(--starbeam-code-background);
    border-radius: var(--starbeam-radius-sm);
    color: var(--starbeam-indigo);
    font-family: var(--starbeam-font-mono);
    font-size: 0.9em;
    padding: 0.1rem 0.24rem;
  }

  @media (max-width: 760px) {
    .topbar,
    nav {
      align-items: flex-start;
      flex-direction: column;
    }

    .topbar {
      gap: 0.75rem;
    }

    nav {
      gap: 0.55rem;
    }

    .principle-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
