---
import StarMark from "./StarMark.astro";
---

<section class="hero">
  <div class="hero__beam" aria-hidden="true"></div>
  <div class="hero__content">
    <h1>Reactivity that stays JavaScript.</h1>
    <p class="lede">
      Mark the root state that changes, then build domain-shaped functions,
      classes, getters, collections, and resources around it as ordinary
      JavaScript.
    </p>
    <div class="hero__actions" aria-label="Primary actions">
      <a class="button button--primary" href="/start/introduction/">Start reading</a>
      <a class="button button--secondary" href="https://github.com/starbeamjs/starbeam">View on GitHub</a>
    </div>
  </div>
  <div class="hero__mark" aria-hidden="true">
    <StarMark class="hero__star" size={520} />
  </div>
</section>

<style>
  .hero {
    align-items: center;
    background:
      radial-gradient(circle at 79% 28%, rgb(255 219 77 / 24%), transparent 14rem),
      radial-gradient(circle at 18% 10%, rgb(0 194 179 / 13%), transparent 22rem),
      linear-gradient(135deg, rgb(255 255 255 / 96%) 0%, rgb(248 255 255 / 86%) 48%, rgb(237 251 251 / 90%) 100%);
    border: 1px solid rgb(255 255 255 / 74%);
    border-radius: clamp(2rem, 6vw, 4.5rem);
    box-sizing: border-box;
    box-shadow: var(--starbeam-shadow-poster);
    display: grid;
    gap: clamp(1.5rem, 4vw, 4rem);
    grid-template-columns: minmax(0, 0.92fr) minmax(18rem, 0.86fr);
    margin: clamp(2rem, 5vw, 4.5rem) auto clamp(3rem, 6vw, 5rem);
    min-height: clamp(32rem, 66vh, 48rem);
    overflow: hidden;
    padding: clamp(2rem, 5vw, 5rem);
    position: relative;
    width: min(88rem, calc(100vw - clamp(2rem, 5vw, 4rem)));
  }

  .hero::before,
  .hero::after {
    content: "";
    pointer-events: none;
    position: absolute;
  }

  .hero::before {
    background:
      linear-gradient(165deg, transparent 0 40%, rgb(255 255 255 / 72%) 40% 55%, transparent 55%),
      linear-gradient(165deg, transparent 0 47%, rgb(0 194 179 / 13%) 47% 64%, transparent 64%);
    block-size: 34rem;
    inline-size: 115%;
    inset-block-end: -15rem;
    inset-inline-end: -12%;
    opacity: 0.92;
  }

  .hero::after {
    background: radial-gradient(circle, rgb(255 219 77 / 32%), transparent 68%);
    block-size: 32rem;
    border-radius: 999px;
    inline-size: 32rem;
    inset-block-start: -11rem;
    inset-inline-end: -8rem;
  }

  .hero__beam {
    background: linear-gradient(90deg, transparent, rgb(255 255 255 / 72%), rgb(0 194 179 / 10%), transparent);
    height: 8rem;
    left: 34%;
    position: absolute;
    right: -8%;
    top: 58%;
    transform: rotate(-12deg);
  }

  .hero__content,
  .hero__mark {
    position: relative;
    z-index: 1;
  }

  .hero__content {
    max-width: 46rem;
  }

  .hero__mark {
    align-self: start;
    justify-self: center;
    margin-block-start: clamp(2rem, 6vw, 5rem);
    margin-inline-end: clamp(-3rem, -3vw, -1rem);
  }

  .hero__star {
    inline-size: clamp(18rem, 35vw, 36rem);
  }

  h1 {
    color: var(--starbeam-ink);
    font-family: "Iowan Old Style", "Palatino Linotype", Palatino, Georgia, serif;
    font-size: clamp(3.85rem, 7vw, 7.75rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 0.98;
    margin: 0;
    max-width: 8.5ch;
    word-spacing: 0.08em;
  }

  .lede {
    color: var(--starbeam-muted);
    font-size: clamp(1.12rem, 1.6vw, 1.32rem);
    line-height: 1.65;
    margin: clamp(1.4rem, 3vw, 2rem) 0 0;
    max-width: 36rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: clamp(2.2rem, 4vw, 3.25rem);
  }

  .button {
    border-radius: 999px;
    display: inline-flex;
    font-size: 0.96rem;
    font-weight: 850;
    letter-spacing: -0.01em;
    padding: 0.95rem 1.25rem;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .button:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--starbeam-focus) 45%, transparent);
    outline-offset: 0.2rem;
  }

  .button:hover,
  .button:focus-visible {
    transform: translateY(-0.08rem);
  }

  .button--primary {
    background: var(--starbeam-link);
    color: #ffffff;
  }

  .button--secondary {
    background: rgb(255 255 255 / 74%);
    border: 1px solid rgb(30 36 54 / 11%);
    color: var(--starbeam-ink);
  }

  @media (max-width: 760px) {
    .hero {
      align-items: start;
      grid-template-columns: 1fr;
      min-height: auto;
      padding-block-end: 0;
    }

    .hero__mark {
      inset-block-start: clamp(6rem, 18vw, 10rem);
      inset-inline-end: clamp(-8rem, -18vw, -5rem);
      opacity: 0.09;
      position: absolute;
      z-index: 0;
    }

    .hero__star {
      inline-size: clamp(15rem, 56vw, 22rem);
    }

  }

  @media (max-width: 540px) {
    .hero {
      border-radius: 2rem;
      padding: 2rem 1.35rem 0;
      width: min(88rem, calc(100vw - clamp(1rem, 5vw, 2rem)));
    }

    h1 {
      font-size: clamp(3.15rem, 14.5vw, 4.45rem);
      letter-spacing: -0.025em;
      line-height: 1;
      max-width: 8.8ch;
      word-spacing: 0.1em;
    }

    .lede {
      font-size: 1.03rem;
      line-height: 1.62;
      margin-block-start: 1.35rem;
      max-width: 29ch;
    }

    .hero__actions {
      align-items: stretch;
      flex-direction: column;
      margin-block-start: 1.75rem;
    }

    .button {
      justify-content: center;
    }

  }

  @media (prefers-reduced-motion: reduce) {
    .button {
      transition: none;
    }

    .button:hover,
    .button:focus-visible {
      transform: none;
    }
  }
</style>
